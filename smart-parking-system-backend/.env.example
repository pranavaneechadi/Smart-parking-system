# Backend Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
MONGO_URI=mongodb://localhost:27017/parking_system
# For MongoDB Atlas: MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/parking_system

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# Email Configuration
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_specific_password

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Google Maps API (Optional - for enhanced features)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Razorpay Configuration (when ready for production)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Admin Email
ADMIN_EMAIL=admin@parkingsystem.com
